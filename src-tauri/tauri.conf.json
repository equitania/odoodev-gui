{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "odoodev-gui",
  "version": "1.2.0",
  "identifier": "de.equitania.odoodev-gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "odoodev — Odoo Development Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "copyright": "Copyright 2026 Equitania Software GmbH",
    "shortDescription": "Odoo Development Manager",
    "longDescription": "Native desktop GUI for the odoodev CLI tool — manage Odoo v16-v19 development environments.",
    "publisher": "Equitania Software GmbH"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/eqms/odoodev-gui/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5MjU2NEM1RUJDNDE3NDkKUldSSkY4VHJ4V1FsYWR1aGZUd0V0SER2eWFXLysyWEhKeXVJM2s0b1FLSXJmTnhhaWoyS1UreVkK"
    }
  }
}